# Lead Hunter AI - Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# Flask server
FLASK_ENV=dev
HOST=0.0.0.0
PORT=5000
SECRET_KEY=change-this-to-a-random-secret-key
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret

# Database / Supabase
DATABASE_URL=sqlite:///leadhunter.db
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# AI and lead-source integrations
GROQ_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=
SERPER_API_KEY=
FIREBALL_API_KEY=

# Maton integrations (Google Calendar, Gmail, and GitHub proxy script)
MATON_API_KEY=

# HubSpot and notifications
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_CLIENT_SECRET=
SLACK_WEBHOOK_URL=
