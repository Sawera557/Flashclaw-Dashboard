# Lead Hunter AI - Environment Variables
# Copy this file to .env and fill in your values

# Flask
FLASK_ENV=dev
SECRET_KEY=change-this-to-a-random-secret-key
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret

# Database
# SQLite (dev): leave unset or sqlite:///leadhunter.db
# PostgreSQL: postgresql://user:password@host:5432/leadhunter
DATABASE_URL=sqlite:///leadhunter.db

# Groq AI (required for AI features)
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=

# HubSpot (CRM integration — private app access token)
# Get from HubSpot Settings > Integrations > Private Apps
HUBSPOT_ACCESS_TOKEN=

# Server
HOST=0.0.0.0
PORT=5000
